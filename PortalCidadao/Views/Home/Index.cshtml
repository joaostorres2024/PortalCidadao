@{
    ViewData["Title"] = "Portal do Cidadão";
}

<div class="container mt-4">

    <div class="bg-primary text-white p-4 rounded mb-4">
        <h2>Portal do Cidadão</h2>
        <p>Bem-vindo ao sistema de serviços digitais</p>
    </div>

    <div class="row">

        <div class="col-md-4 mb-3">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">👤 Cadastro de Pessoas</h5>
                    <p class="card-text">Gerencie informações de cidadãos.</p>
                    <a href="/Pessoa" class="btn btn-primary">Acessar</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">📄 Serviços</h5>
                    <p class="card-text">Solicitação de serviços públicos.</p>
                    <a href="#" class="btn btn-primary">Acessar</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">📊 Consultas</h5>
                    <p class="card-text">Acompanhe solicitações e cadastros.</p>
                    <a href="#" class="btn btn-primary">Ver mais</a>
                </div>
            </div>
        </div>

    </div>
</div>